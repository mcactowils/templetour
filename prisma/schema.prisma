// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Temple {
  id                String   @id @default(cuid())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Basic Information
  name              String   @unique
  slug              String   @unique
  country           String
  state             String?
  city              String
  address           String?
  telephone         String?

  // Important Dates
  announcementDate  DateTime?
  groundbreakingDate DateTime?
  dedicationDate    DateTime?

  // Physical Details
  siteSize          String?
  exteriorFinish    String?
  totalFloorArea    String?
  elevation         String?

  // Features
  instructionRooms  Int?
  sealingRooms      Int?
  baptistry         Boolean  @default(false)
  spires            Int?
  angelMoroni       Boolean  @default(false)

  // Services
  visitorsCenter    Boolean  @default(false)
  arrivalCenter     Boolean  @default(false)
  patronHousing     Boolean  @default(false)
  distributionCenter Boolean @default(false)

  // Location
  latitude          Float?
  longitude         Float?

  // Status
  status            TempleStatus @default(ANNOUNCED)

  // Relations
  schedules         TempleSchedule[]

  @@map("temples")
}

enum TempleStatus {
  ANNOUNCED
  UNDER_CONSTRUCTION
  DEDICATED
  RENOVATING
  CLOSED
}


model User {
  id            String    @id @default(cuid())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  name          String?
  email         String    @unique
  password      String?
  emailVerified DateTime? @map("email_verified")
  image         String?

  // Relations
  createdSchedules   TempleSchedule[]
  attendingSchedules ScheduleAttendee[]
  comments           ScheduleComment[]

  accounts Account[]
  sessions Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verificationtokens")
}

model TempleSchedule {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  templeId    String
  temple      Temple   @relation(fields: [templeId], references: [id])

  createdById String   @map("created_by_id")
  createdBy   User     @relation(fields: [createdById], references: [id])

  scheduledDate DateTime
  title         String
  description   String?

  // Relations
  attendees   ScheduleAttendee[]
  comments    ScheduleComment[]

  @@map("temple_schedules")
}

model ScheduleAttendee {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())

  scheduleId String
  schedule   TempleSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  userId     String
  user       User     @relation(fields: [userId], references: [id])

  @@unique([scheduleId, userId])
  @@map("schedule_attendees")
}

model ScheduleComment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  scheduleId String
  schedule   TempleSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  content   String

  @@map("schedule_comments")
}
