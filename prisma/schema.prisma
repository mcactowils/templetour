generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Temple {
  id                 String           @id @default(cuid())
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  name               String           @unique
  slug               String           @unique
  country            String
  state              String?
  city               String
  address            String?
  telephone          String?
  announcementDate   DateTime?
  groundbreakingDate DateTime?
  dedicationDate     DateTime?
  siteSize           String?
  exteriorFinish     String?
  totalFloorArea     String?
  elevation          String?
  instructionRooms   Int?
  sealingRooms       Int?
  baptistry          Boolean          @default(false)
  spires             Int?
  angelMoroni        Boolean          @default(false)
  visitorsCenter     Boolean          @default(false)
  arrivalCenter      Boolean          @default(false)
  patronHousing      Boolean          @default(false)
  distributionCenter Boolean          @default(false)
  latitude           Float?
  longitude          Float?
  status             TempleStatus     @default(ANNOUNCED)
  schedules          TempleSchedule[]

  @@map("temples")
}

model User {
  id                 String             @id @default(cuid())
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  name               String?
  email              String             @unique
  emailVerified      DateTime?          @map("email_verified")
  image              String?
  password           String?
  isAdmin            Boolean            @default(false)
  accounts           Account[]
  attendingSchedules ScheduleAttendee[]
  comments           ScheduleComment[]
  messages           Message[]
  sessions           Session[]
  createdSchedules   TempleSchedule[]
  notifications      Notification[]
  pushSubscription   String?            // For browser push notifications

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verificationtokens")
}

model TempleSchedule {
  id            String             @id @default(cuid())
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  templeId      String
  createdById   String             @map("created_by_id")
  scheduledDate DateTime
  title         String
  description   String?
  attendees     ScheduleAttendee[]
  comments      ScheduleComment[]
  createdBy     User               @relation(fields: [createdById], references: [id])
  temple        Temple             @relation(fields: [templeId], references: [id])

  @@map("temple_schedules")
}

model ScheduleAttendee {
  id         String         @id @default(cuid())
  createdAt  DateTime       @default(now())
  scheduleId String
  userId     String
  schedule   TempleSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  user       User           @relation(fields: [userId], references: [id])

  @@unique([scheduleId, userId])
  @@map("schedule_attendees")
}

model ScheduleComment {
  id         String         @id @default(cuid())
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  scheduleId String
  userId     String
  content    String
  schedule   TempleSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  user       User           @relation(fields: [userId], references: [id])

  @@map("schedule_comments")
}

model Message {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  content   String
  threadId  String?  // Optional - for threading messages together
  replyToId String?  // Optional - for replying to specific messages
  user      User     @relation(fields: [userId], references: [id])
  replies   Message[] @relation("MessageReplies")
  replyTo   Message? @relation("MessageReplies", fields: [replyToId], references: [id])

  @@map("messages")
}

model Notification {
  id        String            @id @default(cuid())
  createdAt DateTime          @default(now())
  userId    String            @map("user_id")
  type      NotificationType
  title     String
  message   String
  isRead    Boolean           @default(false)
  actionUrl String?           @map("action_url")
  // References to related entities
  scheduleId String?          @map("schedule_id")
  commentId  String?          @map("comment_id")
  messageId  String?          @map("message_id")
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

enum TempleStatus {
  ANNOUNCED
  UNDER_CONSTRUCTION
  DEDICATED
  RENOVATING
  CLOSED
}

enum NotificationType {
  COMMENT_ON_SCHEDULE
  REPLY_TO_MESSAGE
  SCHEDULE_UPDATE
  GENERAL
}
